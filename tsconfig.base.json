{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@poc-company/ui": ["packages/ui/src/index.ts"],
      "@poc-company/sections": ["packages/sections/src/index.ts"],
      "@poc-company/theme": ["packages/theme/src/index.ts"],
      "@poc-company/cms": ["packages/cms/src/index.ts"],
      "@poc-company/cms/blocks": ["packages/cms/src/blocks/index.ts"],
      "@poc-company/cms/rendering/BlockRenderer": [
        "packages/cms/src/rendering/BlockRenderer.ts"
      ],
      "@payload-config": ["packages/cms/payload.config.ts"],
      "@poc-company/lib": ["packages/lib/src/index.ts"]
    },
    "types": ["node"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  }
}
